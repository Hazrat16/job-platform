PORT=
MONGO_URI=
JWT_SECRET=
ADMIN_BOOTSTRAP_SECRET=
RESEND_API_KEY=
BREVO_USER=
BREVO_PASS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSLCOMMERZ (BDT). Register a sandbox store: https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true
# Local sandbox only: public demo merchant from SSLCOMMERZ docs (never enable in production).
# SSLCOMMERZ_ALLOW_TESTBOX=true
# Public base URL of this API (no /api suffix). SSLCOMMERZ redirects and IPN hit this host — use ngrok in local dev for IPN.
API_PUBLIC_BASE_URL=http://127.0.0.1:5000
# Browser URL of the Next.js app (payment callbacks redirect here).
FRONTEND_URL=http://localhost:3000

# Resume / job fit analyzer — any OpenAI-compatible Chat Completions API.
#
# Option A — Groq (generous free tier, no OpenAI account): https://console.groq.com
# GROQ_API_KEY=gsk_...   (OPENAI_BASE_URL is optional — defaults to Groq when this key is set)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
#
# Option B — OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Option C — OpenRouter (some free :free models; keys at openrouter.ai)
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.2-3b-instruct:free
#
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
